# Copy to .env (optional). All have sensible defaults.

# Your public repo URL — shown as `meta.source` in every API response and at
# GET /license, which is how this service satisfies the AGPL network-use clause.
SWISSAPI_SOURCE_URL=https://github.com/richardplrj/swiss-ephemeris-api

# Where the bundled Swiss Ephemeris .se1 files live (defaults to ./ephe).
# SWISSAPI_EPHE_PATH=/app/ephe

# Port to serve on (most PaaS inject this automatically).
# PORT=8080
